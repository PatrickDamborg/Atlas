# ============================================================
# Forge Atlas — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file with real secrets.
# ============================================================

# ---------- Application ----------
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ---------- CORS ----------
# Comma-separated list of allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000"]

# ---------- Azure SQL Database ----------
# ODBC connection string for Azure SQL Serverless
DATABASE_URL=Driver={ODBC Driver 18 for SQL Server};Server=tcp:<your-server>.database.windows.net,1433;Database=forge-atlas-db;Uid=<admin-user>;Pwd=<password>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# ---------- Azure Blob Storage ----------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<storage-account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=uploads

# ---------- Azure Entra ID (MSAL) ----------
AZURE_CLIENT_ID=<your-app-registration-client-id>
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_API_SCOPE=api://<your-client-id>/.default

# ---------- OpenAI ----------
# Use either standard OpenAI OR Azure OpenAI — not both.
OPENAI_API_KEY=sk-...

# ---------- Azure OpenAI (alternative to OpenAI) ----------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-openai-key>
